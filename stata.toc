#!/usr/bin/env python3
"""Build the standalone ESQC GPS Stata/SFI JAR deterministically.

The JAR contains only the reviewed Java bridge and the reviewed Python worker.
Stata's own SFI classes are compile-time dependencies and are never packaged.
All Java classes target Java 11 (class-file major version 55).
"""
from __future__ import annotations

import argparse
import ast
import hashlib
import json
import os
import shutil
import struct
import subprocess
import sys
import tempfile
import zipfile
from pathlib import Path, PurePosixPath

ROOT = Path(__file__).resolve().parents[1]
JAVA_SOURCE = ROOT / "src" / "org" / "worldbank" / "esqc" / "GpsSfi.java"
STUB_ROOT = ROOT / "tests" / "stubs"
WORKER = ROOT / "resources" / "gps_qc.py"
DEFAULT_OUTPUT = ROOT / "esqc_gps.jar"
VERSION = "1.2.0"
TARGET_MAJOR = 55
ZIP_TIME = (1980, 1, 1, 0, 0, 0)


class BuildError(RuntimeError):
    pass


def sha256_bytes(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for block in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(block)
    return digest.hexdigest()


def _compiler() -> str:
    compiler = shutil.which("javac")
    if compiler is None:
        raise BuildError("javac is required to build esqc_gps.jar")
    return compiler


def _validate_source_inputs() -> None:
    for path in (JAVA_SOURCE, WORKER):
        if not path.is_file():
            raise BuildError(f"required source file is missing: {path}")
    stubs = sorted(STUB_ROOT.rglob("*.java"))
    if not stubs:
        raise BuildError(f"Stata SFI compile stubs are missing under {STUB_ROOT}")

    worker_text = WORKER.read_text(encoding="utf-8")
    try:
        ast.parse(worker_text, filename=str(WORKER))
    except SyntaxError as exc:
        raise BuildError(f"Python worker does not compile: {exc}") from exc
    required_worker_tokens = (
        '"gpt-5.6-luna"',
        '"store": True',
        '"prompt_cache_options": {"mode": "implicit", "ttl": "30m"}',
        '"type": "json_schema"',
        "ESQC_GPS_OK",
        "sfi11",
        "MAP_HTML",
        "Google Hybrid",
        "openai_store_policy=\"forced_true\"",
        "MAP_HTML",
        "Google Hybrid",
    )
    for token in required_worker_tokens:
        if token not in worker_text:
            raise BuildError(f"Python worker is missing required contract token: {token}")
    forbidden = (
        "prompt_cache_retention",
        "sk-proj-",
        "sk-live-",
    )
    for token in forbidden:
        if token in worker_text:
            raise BuildError(f"Python worker contains forbidden token: {token}")


def _compile_java(classes: Path) -> None:
    sources = sorted(STUB_ROOT.rglob("*.java")) + [JAVA_SOURCE]
    command = [_compiler(), "--release", "11", "-encoding", "UTF-8", "-d", str(classes)]
    command.extend(str(path) for path in sources)
    completed = subprocess.run(
        command,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
        timeout=120,
    )
    if completed.returncode != 0:
        raise BuildError("javac failed:\n" + (completed.stderr or completed.stdout))


def _class_major(data: bytes) -> int:
    if len(data) < 8 or data[:4] != b"\xca\xfe\xba\xbe":
        raise BuildError("invalid Java class file")
    return struct.unpack(">H", data[6:8])[0]


def _manifest() -> bytes:
    lines = [
        "Manifest-Version: 1.0",
        "Implementation-Title: ESQC GPS Stata SFI bridge",
        f"Implementation-Version: {VERSION}",
        "Implementation-Vendor: Attique Ur Rehman, Enterprise Analysis Unit, World Bank",
        "Built-With: GPT-5.6 Sol Ultra",
        "Build-Java-Release: 11",
        "",
    ]
    return "\r\n".join(lines).encode("utf-8")


def _zip_info(name: str) -> zipfile.ZipInfo:
    pure = PurePosixPath(name)
    if pure.is_absolute() or ".." in pure.parts or "\\" in name:
        raise BuildError(f"unsafe JAR member name: {name}")
    info = zipfile.ZipInfo(name, ZIP_TIME)
    info.compress_type = zipfile.ZIP_DEFLATED
    info.create_system = 3
    info.external_attr = (0o100644 & 0xFFFF) << 16
    info.flag_bits |= 0x800
    return info


def _write_jar(path: Path, entries: dict[str, bytes]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, temp_name = tempfile.mkstemp(prefix=path.name + ".", suffix=".tmp", dir=str(path.parent))
    os.close(fd)
    temp_path = Path(temp_name)
    try:
        with zipfile.ZipFile(temp_path, "w", compression=zipfile.ZIP_DEFLATED, compresslevel=9) as archive:
            for name in sorted(entries):
                archive.writestr(_zip_info(name), entries[name], compress_type=zipfile.ZIP_DEFLATED, compresslevel=9)
        os.replace(temp_path, path)
    except Exception:
        temp_path.unlink(missing_ok=True)
        raise


def build(output: Path) -> Path:
    _validate_source_inputs()
    with tempfile.TemporaryDirectory(prefix="esqc-gps-javac-") as temp:
        classes = Path(temp) / "classes"
        classes.mkdir()
        _compile_java(classes)

        entries: dict[str, bytes] = {
            "META-INF/MANIFEST.MF": _manifest(),
            "resources/gps_qc.py": WORKER.read_bytes(),
        }
        class_names: list[str] = []
        for class_file in sorted((classes / "org" / "worldbank" / "esqc").glob("GpsSfi*.class")):
            relative = class_file.relative_to(classes).as_posix()
            data = class_file.read_bytes()
            major = _class_major(data)
            if major != TARGET_MAJOR:
                raise BuildError(f"{relative} targets class-file major {major}, expected {TARGET_MAJOR}")
            entries[relative] = data
            class_names.append(relative)

        if "org/worldbank/esqc/GpsSfi.class" not in entries:
            raise BuildError("GpsSfi.class was not emitted")
        if any(name.startswith("com/stata/") for name in entries):
            raise BuildError("Stata SFI stubs must not be packaged")

        metadata = {
            "version": VERSION,
            "java_release": 11,
            "java_class_major": TARGET_MAJOR,
            "default_model": "gpt-5.6-luna",
            "author": "Attique Ur Rehman, Enterprise Analysis Unit, World Bank",
            "development_assistance": "GPT-5.6 Sol Ultra",
            "java_source": {
                "path": JAVA_SOURCE.relative_to(ROOT).as_posix(),
                "sha256": sha256_file(JAVA_SOURCE),
            },
            "python_worker": {
                "path": WORKER.relative_to(ROOT).as_posix(),
                "sha256": sha256_file(WORKER),
            },
            "classes": sorted(class_names),
        }
        entries["META-INF/esqc-gps-build.json"] = (
            json.dumps(metadata, ensure_ascii=False, sort_keys=True, indent=2) + "\n"
        ).encode("utf-8")
        _write_jar(output, entries)
    validate(output)
    return output


def validate(path: Path) -> None:
    if not path.is_file():
        raise BuildError(f"JAR does not exist: {path}")
    with zipfile.ZipFile(path) as archive:
        infos = archive.infolist()
        names = [info.filename for info in infos]
        if len(names) != len(set(names)):
            raise BuildError("JAR contains duplicate members")
        required = {
            "META-INF/MANIFEST.MF",
            "META-INF/esqc-gps-build.json",
            "org/worldbank/esqc/GpsSfi.class",
            "resources/gps_qc.py",
        }
        missing = required.difference(names)
        if missing:
            raise BuildError("JAR is missing: " + ", ".join(sorted(missing)))
        if any(name.startswith("com/stata/") for name in names):
            raise BuildError("JAR improperly packages Stata SFI stubs")
        for info in infos:
            pure = PurePosixPath(info.filename)
            if pure.is_absolute() or ".." in pure.parts or "\\" in info.filename:
                raise BuildError(f"unsafe JAR member: {info.filename}")
            if tuple(info.date_time) != ZIP_TIME:
                raise BuildError(f"nondeterministic ZIP timestamp: {info.filename}")
            if info.filename.endswith(".class"):
                major = _class_major(archive.read(info.filename))
                if major != TARGET_MAJOR:
                    raise BuildError(f"{info.filename} has class major {major}")

        metadata = json.loads(archive.read("META-INF/esqc-gps-build.json"))
        if metadata.get("version") != VERSION:
            raise BuildError("JAR build metadata version mismatch")
        if metadata.get("default_model") != "gpt-5.6-luna":
            raise BuildError("JAR build metadata model mismatch")
        if metadata["java_source"]["sha256"] != sha256_file(JAVA_SOURCE):
            raise BuildError("JAR Java source digest is stale")
        if metadata["python_worker"]["sha256"] != sha256_file(WORKER):
            raise BuildError("JAR Python worker digest is stale")
        worker_data = archive.read("resources/gps_qc.py")
        if sha256_bytes(worker_data) != metadata["python_worker"]["sha256"]:
            raise BuildError("embedded worker does not match build metadata")


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--output", type=Path, default=DEFAULT_OUTPUT)
    parser.add_argument("--validate-only", action="store_true")
    args = parser.parse_args()
    try:
        if args.validate_only:
            validate(args.output.resolve())
        else:
            output = build(args.output.resolve())
            print(f"built {output} ({output.stat().st_size} bytes, sha256={sha256_file(output)})")
        return 0
    except (BuildError, OSError, subprocess.SubprocessError, zipfile.BadZipFile) as exc:
        print(f"build error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

WORKER_VERSION = "1.2.0"
RESULT_SCHEMA = "sfi11"
RESULT_COLUMNS = [
    "row_id",
    "tid",
    "lat",
    "lon",
    "gps_status",
    "gps_flag",
    "predicted_admin2",
    "predicted_admin1",

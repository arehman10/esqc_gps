#!/usr/bin/env python3
"""ESQC GPS QC worker for the Stata ``esqc_gps`` command.

The worker is deliberately independent of Stata.  It reads a JSON
configuration file, consumes JSON Lines written by the Java/SFI bridge, runs
local GIS checks, optionally asks a GPT-5.6 model to review ambiguous labels
and outside-country boundary cases, and writes a strict eleven-column CSV.

Author: Attique Ur Rehman, Enterprise Analysis Unit, World Bank.
Developed with help of GPT-5.6 Sol Ultra.

Security properties:
* API keys are accepted only from the ``ESQC_AI_KEY`` process environment.
* OpenAI Responses are always created with ``store=true``.
* Survey location labels are treated as untrusted data in every prompt.
* ZIP extraction rejects traversal, absolute paths, and symlinks.
* A success marker is written only after every requested output is complete.
"""
from __future__ import annotations
# === ESQC GPS FULL AUDIT INSTRUMENTATION v1.2.0 ===
# This block is deliberately self-contained and uses only the Python standard
# library until the HTTP clients used by the worker are patched.
import atexit as _esqc_atexit
import base64 as _esqc_base64
import builtins as _esqc_builtins
import datetime as _esqc_datetime
import hashlib as _esqc_hashlib
import json as _esqc_json
import os as _esqc_os
from pathlib import Path as _EsqcPath
import re as _esqc_re
import sys as _esqc_sys
import tempfile as _esqc_tempfile
import threading as _esqc_threading
import time as _esqc_time
import traceback as _esqc_traceback
import uuid as _esqc_uuid

_ESQC_AUDIT_SCHEMA = "esqc-gps-full-audit/1.2.0"
_ESQC_STARTED_MONOTONIC = _esqc_time.monotonic()
_ESQC_RUN_ID = _esqc_uuid.uuid4().hex
_ESQC_SECRET_KEY_RE = _esqc_re.compile(
    r"(?:authorization|proxy-authorization|api[-_]?key|access[-_]?token|refresh[-_]?token|password|passwd|secret|cookie|set-cookie)",
    _esqc_re.I,
)
_ESQC_SK_RE = _esqc_re.compile(r"\bsk-[A-Za-z0-9_\-]{8,}\b")
_ESQC_BEARER_RE = _esqc_re.compile(r"(?i)\bBearer\s+[A-Za-z0-9._~+/=\-]+")
_ESQC_DATA_URL_RE = _esqc_re.compile(r"^data:([^;,]+)?(?:;charset=[^;,]+)?;base64,(.*)$", _esqc_re.S)


def _esqc_utc_now():
    return _esqc_datetime.datetime.now(_esqc_datetime.timezone.utc).isoformat(timespec="milliseconds")


def _esqc_log_dir():
    override = _esqc_os.environ.get("ESQC_GPS_LOG_DIR", "").strip()
    if override:
        return _EsqcPath(override).expanduser()
    if _esqc_os.name == "nt":
        base = _esqc_os.environ.get("LOCALAPPDATA", "").strip()
        if base:
            return _EsqcPath(base) / "esqc_gps" / "logs"
        return _EsqcPath.home() / "AppData" / "Local" / "esqc_gps" / "logs"
    state = _esqc_os.environ.get("XDG_STATE_HOME", "").strip()
    if state:
        return _EsqcPath(state) / "esqc_gps" / "logs"
    return _EsqcPath.home() / ".local" / "state" / "esqc_gps" / "logs"


def _esqc_choose_logfile():
    explicit = _esqc_os.environ.get("ESQC_GPS_LOGFILE", "").strip()
    if explicit:
        path = _EsqcPath(explicit).expanduser()
        path.parent.mkdir(parents=True, exist_ok=True)
        return path
    directory = _esqc_log_dir()
    directory.mkdir(parents=True, exist_ok=True)
    stamp = _esqc_datetime.datetime.now(_esqc_datetime.timezone.utc).strftime("%Y%m%dT%H%M%S.%fZ")
    return directory / ("esqc_gps_%s_pid%s_%s.jsonl" % (stamp, _esqc_os.getpid(), _ESQC_RUN_ID[:12]))


def _esqc_redact_string(value):
    value = _ESQC_SK_RE.sub("[REDACTED_OPENAI_KEY]", str(value))
    value = _ESQC_BEARER_RE.sub("Bearer [REDACTED]", value)
    return value


def _esqc_scrub(value, key_hint=""):
    if key_hint and _ESQC_SECRET_KEY_RE.search(str(key_hint)):
        return "[REDACTED_SECRET]"
    if isinstance(value, dict):
        return {str(k): _esqc_scrub(v, str(k)) for k, v in value.items()}
    if isinstance(value, (list, tuple)):
        return [_esqc_scrub(v) for v in value]
    if isinstance(value, bytes):
        return _esqc_store_artifact(value, "application/octet-stream", "bytes")
    if isinstance(value, str):
        match = _ESQC_DATA_URL_RE.match(value)
        if match and len(value) > 4096:
            mime = match.group(1) or "application/octet-stream"
            try:
                raw = _esqc_base64.b64decode(match.group(2), validate=False)
            except Exception:
                raw = value.encode("utf-8", "replace")
                mime = "text/plain"
            return _esqc_store_artifact(raw, mime, "data_url")
        return _esqc_redact_string(value)
    if value is None or isinstance(value, (bool, int, float)):
        return value
    return _esqc_redact_string(repr(value))


_ESQC_LOGFILE = _esqc_choose_logfile()
_ESQC_ARTIFACT_DIR = _ESQC_LOGFILE.with_suffix("")
_ESQC_ARTIFACT_DIR = _ESQC_ARTIFACT_DIR.parent / (_ESQC_ARTIFACT_DIR.name + "_artifacts")
_ESQC_LOCK = _esqc_threading.RLock()
_ESQC_SEQ = 0
_ESQC_FINISHED = False
_ESQC_FILE = open(_ESQC_LOGFILE, "x", encoding="utf-8", newline="\n", buffering=1)


def _esqc_store_artifact(raw, mime, kind):
    if not isinstance(raw, (bytes, bytearray)):
        raw = str(raw).encode("utf-8", "replace")
    raw = bytes(raw)
    digest = _esqc_hashlib.sha256(raw).hexdigest()
    suffixes = {
        "image/png": ".png",
        "image/jpeg": ".jpg",
        "image/webp": ".webp",
        "application/json": ".json",
        "text/plain": ".txt",
    }
    suffix = suffixes.get(str(mime).split(";", 1)[0].lower(), ".bin")
    _ESQC_ARTIFACT_DIR.mkdir(parents=True, exist_ok=True)
    target = _ESQC_ARTIFACT_DIR / (digest + suffix)
    if not target.exists():
        tmp = target.with_name(target.name + ".tmp-" + _ESQC_RUN_ID[:8])
        with open(tmp, "wb") as fh:
            fh.write(raw)
            fh.flush()
            _esqc_os.fsync(fh.fileno())
        _esqc_os.replace(tmp, target)
    return {
        "$artifact": str(target),
        "kind": kind,
        "mime": mime,
        "bytes": len(raw),
        "sha256": digest,
    }


def _esqc_log(event, **fields):
    global _ESQC_SEQ
    with _ESQC_LOCK:
        _ESQC_SEQ += 1
        record = {
            "schema": _ESQC_AUDIT_SCHEMA,
            "run_id": _ESQC_RUN_ID,
            "seq": _ESQC_SEQ,
            "time_utc": _esqc_utc_now(),
            "event": str(event),
        }
        for key, value in fields.items():
            record[str(key)] = _esqc_scrub(value, str(key))
        line = _esqc_json.dumps(record, ensure_ascii=False, separators=(",", ":"), default=repr)
        _ESQC_FILE.write(line + "\n")
        _ESQC_FILE.flush()
        _esqc_os.fsync(_ESQC_FILE.fileno())


def _esqc_write_latest_pointer():
    directory = _ESQC_LOGFILE.parent
    directory.mkdir(parents=True, exist_ok=True)
    target = directory / "latest.txt"
    tmp = directory / ("latest.txt.tmp-" + _ESQC_RUN_ID[:12])
    with open(tmp, "w", encoding="utf-8", newline="\n") as fh:
        fh.write(str(_ESQC_LOGFILE) + "\n")
        fh.flush()
        _esqc_os.fsync(fh.fileno())
    _esqc_os.replace(tmp, target)


def _esqc_safe_environment():
    result = {}
    for key, value in _esqc_os.environ.items():
        if _ESQC_SECRET_KEY_RE.search(key) or key.upper() in {"OPENAI_API_KEY"}:
            result[key] = "[REDACTED_SECRET]"
        elif key.upper() in {"PATH", "PYTHONPATH", "JAVA_HOME", "TEMP", "TMP", "USERPROFILE", "HOME", "LOCALAPPDATA", "XDG_STATE_HOME"} or key.startswith("ESQC_"):
            result[key] = _esqc_redact_string(value)
    return result


def _esqc_hash_file(path):
    digest = _esqc_hashlib.sha256()
    size = 0
    with open(path, "rb") as fh:
        while True:
            block = fh.read(1024 * 1024)
            if not block:
                break
            size += len(block)
            digest.update(block)
    return size, digest.hexdigest()


def _esqc_path_snapshot(raw_path):
    path = _EsqcPath(raw_path)
    try:
        if not path.exists() or not path.is_file():
            return {"path": str(path), "exists": False}
        size, digest = _esqc_hash_file(path)
        item = {"path": str(path.resolve()), "exists": True, "bytes": size, "sha256": digest}
        lower_name = path.name.lower()
        secret_name = any(token in lower_name for token in ("key", "secret", "token", "password", "credential"))
        text_ext = path.suffix.lower() in {".json", ".jsonl", ".csv", ".txt", ".geojson", ".html", ".log", ".out"}
        if text_ext and size <= 50 * 1024 * 1024 and not secret_name:
            text = path.read_text(encoding="utf-8", errors="replace")
            try:
                item["content"] = _esqc_scrub(_esqc_json.loads(text))
            except Exception:
                item["content"] = _esqc_redact_string(text)
        elif secret_name:
            item["content"] = "[REDACTED_SECRET_FILE]"
        return item
    except Exception as exc:
        return {"path": str(path), "snapshot_error": repr(exc)}


def _esqc_argv_file_snapshots():
    items = []
    seen = set()
    for value in _esqc_sys.argv[1:]:
        candidate = str(value)
        if candidate.startswith("-") or candidate in seen:
            continue
        seen.add(candidate)
        try:
            path = _EsqcPath(candidate)
            if path.exists() and path.is_file():
                items.append(_esqc_path_snapshot(path))
        except Exception:
            pass
    return items


def _esqc_referenced_file_snapshots():
    """Snapshot files named by the worker config without logging secrets."""
    if len(_esqc_sys.argv) < 2:
        return []
    try:
        config_path = _EsqcPath(_esqc_sys.argv[1])
        if not config_path.is_file():
            return []
        config = _esqc_json.loads(config_path.read_text(encoding="utf-8"))
        if not isinstance(config, dict):
            return []
    except Exception:
        return []
    keys = (
        "INPUT_JSONL", "OUTPUT_CSV", "SUCCESS_MARKER", "CACHE_FILE",
        "MAP_GEOJSON", "MAP_HTML", "AI_LOG", "SHP_PATH",
    )
    items = []
    seen = set()
    for key in keys:
        value = str(config.get(key, "") or "").strip()
        if not value or value in seen:
            continue
        seen.add(value)
        try:
            path = _EsqcPath(value)
            if path.exists() and path.is_file():
                item = _esqc_path_snapshot(path)
            elif path.exists() and path.is_dir():
                item = {"path": str(path.resolve()), "exists": True, "directory": True}
            else:
                item = {"path": str(path), "exists": False}
            item["config_key"] = key
            items.append(item)
        except Exception as exc:
            items.append({"config_key": key, "path": value, "snapshot_error": repr(exc)})
    return items


class _EsqcTee:
    def __init__(self, original, stream_name):
        self._original = original
        self._name = stream_name
        self._lock = _esqc_threading.RLock()

    @property
    def encoding(self):
        return getattr(self._original, "encoding", "utf-8")

    def isatty(self):
        return bool(getattr(self._original, "isatty", lambda: False)())

    def fileno(self):
        return self._original.fileno()

    def write(self, text):
        with self._lock:
            result = self._original.write(text)
            if text:
                _esqc_log("stream", stream=self._name, text=str(text))
            return result

    def flush(self):
        return self._original.flush()

    def __getattr__(self, name):
        return getattr(self._original, name)


def _esqc_is_responses_url(url):
    try:
        path = getattr(url, "path", None)
        if path is None:
            from urllib.parse import urlsplit as _esqc_urlsplit
            path = _esqc_urlsplit(str(url)).path
        path = str(path).rstrip("/").lower()
        return path.endswith("/responses")
    except Exception:
        return str(url).lower().split("?", 1)[0].rstrip("/").endswith("/responses")


def _esqc_force_store_bytes(body):
    if body is None:
        return body, False
    was_text = isinstance(body, str)
    raw = body.encode("utf-8") if was_text else bytes(body)
    try:
        obj = _esqc_json.loads(raw.decode("utf-8"))
    except Exception:
        return body, False
    if not isinstance(obj, dict):
        return body, False
    obj["store"] = True
    encoded = _esqc_json.dumps(obj, ensure_ascii=False, separators=(",", ":")).encode("utf-8")
    return (encoded.decode("utf-8") if was_text else encoded), True


def _esqc_body_snapshot(body, content_type=""):
    if body is None:
        return None
    if isinstance(body, str):
        raw = body.encode("utf-8", "replace")
    else:
        try:
            raw = bytes(body)
        except Exception:
            return _esqc_scrub(repr(body))
    content_type = str(content_type or "")
    if "json" in content_type.lower() or raw[:1] in (b"{", b"["):
        try:
            return _esqc_scrub(_esqc_json.loads(raw.decode("utf-8")))
        except Exception:
            pass
    if content_type.lower().startswith("text/") or len(raw) <= 1024 * 1024:
        try:
            return _esqc_redact_string(raw.decode("utf-8"))
        except Exception:
            pass
    return _esqc_store_artifact(raw, content_type or "application/octet-stream", "http_body")


def _esqc_headers_snapshot(headers):
    try:
        pairs = list(headers.multi_items())
    except Exception:
        try:
            pairs = list(headers.items())
        except Exception:
            return _esqc_scrub(repr(headers))
    result = []
    for key, value in pairs:
        if _ESQC_SECRET_KEY_RE.search(str(key)):
            value = "[REDACTED_SECRET]"
        else:
            value = _esqc_redact_string(value)
        result.append([str(key), value])
    return result


def _esqc_patch_httpx():
    try:
        import httpx as _esqc_httpx
    except Exception as exc:
        _esqc_log("audit_patch_unavailable", library="httpx", error=repr(exc))
        return

    if getattr(_esqc_httpx.Client.send, "_esqc_full_audit", False):
        return

    original_send = _esqc_httpx.Client.send
    original_async_send = _esqc_httpx.AsyncClient.send

    def audited_send(self, request, *args, **kwargs):
        request_id = _esqc_uuid.uuid4().hex
        outgoing = request
        store_forced = False
        try:
            body = request.content
        except Exception:
            body = None
        if _esqc_is_responses_url(request.url):
            new_body, changed = _esqc_force_store_bytes(body)
            if changed:
                headers = dict(request.headers)
                headers.pop("content-length", None)
                headers.pop("Content-Length", None)
                outgoing = _esqc_httpx.Request(
                    method=request.method,
                    url=request.url,
                    headers=headers,
                    content=new_body,
                    extensions=dict(getattr(request, "extensions", {}) or {}),
                )
                body = new_body
                store_forced = True
        _esqc_log(
            "http_request",
            request_id=request_id,
            library="httpx",
            method=outgoing.method,
            url=str(outgoing.url),
            headers=_esqc_headers_snapshot(outgoing.headers),
            body=_esqc_body_snapshot(body, outgoing.headers.get("content-type", "")),
            openai_store_forced=store_forced,
        )
        started = _esqc_time.monotonic()
        try:
            response = original_send(self, outgoing, *args, **kwargs)
            try:
                response.read()
            except Exception:
                pass
            try:
                response_body = response.content
            except Exception:
                response_body = None
            _esqc_log(
                "http_response",
                request_id=request_id,
                library="httpx",
                status_code=response.status_code,
                reason_phrase=getattr(response, "reason_phrase", ""),
                headers=_esqc_headers_snapshot(response.headers),
                body=_esqc_body_snapshot(response_body, response.headers.get("content-type", "")),
                elapsed_ms=round((_esqc_time.monotonic() - started) * 1000, 3),
            )
            return response
        except BaseException as exc:
            _esqc_log(
                "http_error",
                request_id=request_id,
                library="httpx",
                error=repr(exc),
                traceback="".join(_esqc_traceback.format_exception(type(exc), exc, exc.__traceback__)),
                elapsed_ms=round((_esqc_time.monotonic() - started) * 1000, 3),
            )
            raise

    async def audited_async_send(self, request, *args, **kwargs):
        request_id = _esqc_uuid.uuid4().hex
        outgoing = request
        store_forced = False
        try:
            body = request.content
        except Exception:
            body = None
        if _esqc_is_responses_url(request.url):
            new_body, changed = _esqc_force_store_bytes(body)
            if changed:
                headers = dict(request.headers)
                headers.pop("content-length", None)
                headers.pop("Content-Length", None)
                outgoing = _esqc_httpx.Request(
                    method=request.method,
                    url=request.url,
                    headers=headers,
                    content=new_body,
                    extensions=dict(getattr(request, "extensions", {}) or {}),
                )
                body = new_body
                store_forced = True
        _esqc_log(
            "http_request",
            request_id=request_id,
            library="httpx-async",
            method=outgoing.method,
            url=str(outgoing.url),
            headers=_esqc_headers_snapshot(outgoing.headers),
            body=_esqc_body_snapshot(body, outgoing.headers.get("content-type", "")),
            openai_store_forced=store_forced,
        )
        started = _esqc_time.monotonic()
        try:
            response = await original_async_send(self, outgoing, *args, **kwargs)
            try:
                await response.aread()
            except Exception:
                pass
            try:
                response_body = response.content
            except Exception:
                response_body = None
            _esqc_log(
                "http_response",
                request_id=request_id,
                library="httpx-async",
                status_code=response.status_code,
                reason_phrase=getattr(response, "reason_phrase", ""),
                headers=_esqc_headers_snapshot(response.headers),
                body=_esqc_body_snapshot(response_body, response.headers.get("content-type", "")),
                elapsed_ms=round((_esqc_time.monotonic() - started) * 1000, 3),
            )
            return response
        except BaseException as exc:
            _esqc_log(
                "http_error",
                request_id=request_id,
                library="httpx-async",
                error=repr(exc),
                traceback="".join(_esqc_traceback.format_exception(type(exc), exc, exc.__traceback__)),
                elapsed_ms=round((_esqc_time.monotonic() - started) * 1000, 3),
            )
            raise

    audited_send._esqc_full_audit = True
    audited_async_send._esqc_full_audit = True
    _esqc_httpx.Client.send = audited_send
    _esqc_httpx.AsyncClient.send = audited_async_send
    _esqc_log("audit_patch_installed", library="httpx")


def _esqc_patch_requests():
    try:
        import requests as _esqc_requests
    except Exception as exc:
        _esqc_log("audit_patch_unavailable", library="requests", error=repr(exc))
        return
    if getattr(_esqc_requests.Session.send, "_esqc_full_audit", False):
        return
    original_send = _esqc_requests.Session.send

    def audited_send(self, request, **kwargs):
        request_id = _esqc_uuid.uuid4().hex
        store_forced = False
        if _esqc_is_responses_url(request.url):
            new_body, changed = _esqc_force_store_bytes(request.body)
            if changed:
                request.body = new_body
                request.headers["Content-Length"] = str(len(new_body.encode("utf-8") if isinstance(new_body, str) else new_body))
                store_forced = True
        _esqc_log(
            "http_request",
            request_id=request_id,
            library="requests",
            method=request.method,
            url=str(request.url),
            headers=_esqc_headers_snapshot(request.headers),
            body=_esqc_body_snapshot(request.body, request.headers.get("Content-Type", "")),
            openai_store_forced=store_forced,
        )
        started = _esqc_time.monotonic()
        try:
            response = original_send(self, request, **kwargs)
            body = response.content
            _esqc_log(
                "http_response",
                request_id=request_id,
                library="requests",
                status_code=response.status_code,
                reason_phrase=getattr(response, "reason", ""),
                headers=_esqc_headers_snapshot(response.headers),
                body=_esqc_body_snapshot(body, response.headers.get("Content-Type", "")),
                elapsed_ms=round((_esqc_time.monotonic() - started) * 1000, 3),
            )
            return response
        except BaseException as exc:
            _esqc_log(
                "http_error",
                request_id=request_id,
                library="requests",
                error=repr(exc),
                traceback="".join(_esqc_traceback.format_exception(type(exc), exc, exc.__traceback__)),
                elapsed_ms=round((_esqc_time.monotonic() - started) * 1000, 3),
            )
            raise

    audited_send._esqc_full_audit = True
    _esqc_requests.Session.send = audited_send
    _esqc_log("audit_patch_installed", library="requests")


def _esqc_unhandled_exception(exc_type, exc, tb):
    _esqc_log(
        "unhandled_exception",
        error=repr(exc),
        traceback="".join(_esqc_traceback.format_exception(exc_type, exc, tb)),
    )
    return _ESQC_ORIGINAL_EXCEPTHOOK(exc_type, exc, tb)


def _esqc_finish():
    global _ESQC_FINISHED
    if _ESQC_FINISHED:
        return
    _ESQC_FINISHED = True
    try:
        _esqc_log(
            "run_finished",
            elapsed_ms=round((_esqc_time.monotonic() - _ESQC_STARTED_MONOTONIC) * 1000, 3),
            argv_files_after=_esqc_argv_file_snapshots(),
            referenced_files_after=_esqc_referenced_file_snapshots(),
        )
        _esqc_write_latest_pointer()
    finally:
        try:
            _ESQC_FILE.flush()
            _esqc_os.fsync(_ESQC_FILE.fileno())
            _ESQC_FILE.close()
        except Exception:
            pass


# Fail closed: no QC or API call is allowed unless a durable audit log exists.
_esqc_write_latest_pointer()
_esqc_log(
    "run_started",
    audit_log=str(_ESQC_LOGFILE),
    artifact_directory=str(_ESQC_ARTIFACT_DIR),
    pid=_esqc_os.getpid(),
    ppid=_esqc_os.getppid() if hasattr(_esqc_os, "getppid") else None,
    python=_esqc_sys.version,
    executable=_esqc_sys.executable,
    cwd=_esqc_os.getcwd(),
    argv=list(_esqc_sys.argv),
    environment=_esqc_safe_environment(),
    argv_files_before=_esqc_argv_file_snapshots(),
    openai_store_policy="forced_true",
    log_policy="always_full",
)
_ESQC_ORIGINAL_STDOUT = _esqc_sys.stdout
_ESQC_ORIGINAL_STDERR = _esqc_sys.stderr
_ESQC_ORIGINAL_EXCEPTHOOK = _esqc_sys.excepthook
_esqc_sys.stdout = _EsqcTee(_ESQC_ORIGINAL_STDOUT, "stdout")
_esqc_sys.stderr = _EsqcTee(_ESQC_ORIGINAL_STDERR, "stderr")
_esqc_sys.excepthook = _esqc_unhandled_exception
_esqc_atexit.register(_esqc_finish)
_esqc_patch_httpx()
_esqc_patch_requests()
try:
